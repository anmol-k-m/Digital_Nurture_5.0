<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>

    <!-- To establish connection -->
    <session-factory>

        <!-- MySQL Driver -->
        <property name="hibernate.connection.driver.class">com.mysql.jdbc.Driver</property>
        <!-- Database URL -->
        <property name="hibernate.connection.url">JDBC:mysql://localhost:3306/employee_management_system</property>
        <!-- Database USERNAME -->
        <property name="hibernate.connection.username">root</property>
        <!-- Database PASSWORD -->
        <property name="hibernate.connection.password">12qw</property>

        <!-- Automatically create/update tables -->
        <property name="hibernate.hbm2ddl.auto">update</property>
        <!-- Show SQL Query in terminal -->
        <property name="hibernate.show_sql">true</property>
        <!-- Format SQL Query -->
        <property name="hibernate.format_sql">true</property>

        <property name="hibernate.dialect">org.hibernate.dialect.MySQLDialect</property>

        <!-- entity class -> create table in db-->
        <mapping class="com.employee.entity.Employee" />
        <mapping class="com.employee.entity.Student" />

    </session-factory>


</hibernate-configuration>