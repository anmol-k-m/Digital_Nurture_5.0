                {
                    "name": "addStudent",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "pm.variables.set(\"id\", Math.floor(Math.random() * 10000));",
                                    "",
                                    "pm.variables.set(",
                                    "    \"name\",",
                                    "    pm.variables.replaceIn(\"{{$randomFirstName}} {{$randomLastName}}\")",
                                    ");",
                                    "",
                                    "pm.variables.set(",
                                    "    \"email\",",
                                    "    pm.variables.replaceIn(\"{{$randomEmail}}\")",
                                    ");",
                                    "",
                                    "pm.variables.set(",
                                    "    \"age\",",
                                    "    Math.floor(Math.random() * 8) + 18",
                                    ");"
                                ],
                                "type": "text/javascript",
                                "packages": {},
                                "requests": {}
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "",
                                    "// 1. Status code is 200 or 201",
                                    "pm.test(\"Status code is 200 or 201\", function () {",
                                    "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                                    "});",
                                    "",
                                    "// 2. Response body is JSON",
                                    "pm.test(\"Response body is JSON\", function () {",
                                    "    pm.response.to.be.json;",
                                    "});",
                                    "",
                                    "// 3. Response has all required fields: id, name, email, age",
                                    "pm.test(\"Response has all required fields: id, name, email, age\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.have.property(\"id\");",
                                    "    pm.expect(jsonData).to.have.property(\"name\");",
                                    "    pm.expect(jsonData).to.have.property(\"email\");",
                                    "    pm.expect(jsonData).to.have.property(\"age\");",
                                    "});",
                                    "",
                                    "// 4. id is a number",
                                    "pm.test(\"id is a number\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.id).to.be.a(\"number\");",
                                    "});",
                                    "",
                                    "// 5. name is a string and is not empty",
                                    "pm.test(\"name is a string and is not empty\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.name).to.be.a(\"string\").and.to.not.be.empty;",
                                    "});",
                                    "",
                                    "// 6. email is a string and matches a basic email format",
                                    "pm.test(\"email is a string and matches a basic email format\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.email).to.be.a(\"string\");",
                                    "    pm.expect(jsonData.email).to.match(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/);",
                                    "});",
                                    "",
                                    "// 7. age is a number and is between 18 and 25",
                                    "pm.test(\"age is a number and is between 18 and 25\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.age).to.be.a(\"number\");",
                                    "    pm.expect(jsonData.age).to.be.at.least(18);",
                                    "    pm.expect(jsonData.age).to.be.at.most(25);",
                                    "});",
                                    "",
                                    "// 8. Response time is less than 2000ms",
                                    "pm.test(\"Response time is less than 2000ms\", function () {",
                                    "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                                    "});",
                                    ""
                                ],
                                "type": "text/javascript",
                                "packages": {},
                                "requests": {}
                            }
                        }
                    ],
